A1=ALLTRIM(STR(YEAR(MDATEFROM)))
A2=SUBSTR(A1,3,2)
B1=ALLTRIM(STR(YEAR(MDATETO)))
B2=SUBSTR(B1,3,2)
FY=A2+"-"+B2

C1=ALLTRIM(STR(DAY(DATE())))
C2=ALLTRIM(STR(MONTH(DATE())))
C3=ALLTRIM(STR(YEAR(DATE())))
C3=SUBSTR(C3,3,2)

T=TIME()
T1=SUBSTR(T,1,2)
T2=SUBSTR(T,4,2)
TT=T1+'.'+T2

S=C1+'.'+C2+'.'+C3


FILENAME='\FUELTRACKER\BKP\'+FY+'\'+'&S'+'\'+TT
ON ERROR SET TALK OFF
MD(FILENAME)
ON ERROR

CLOSE DATABASES

SFROMPATH1=DATAPATH+"\"+"*.&MCODE"
SFROMPATH2=DATAPATH+"\"+"*.$$$"

ON ERROR SET TALK OFF
*COPY FILE \FUELTRACKER\DATA\*.&MCODE TO &FILENAME
COPY FILE \FUELTRACKER\DATA\*.$$$ TO &FILENAME

COPY FILE &SFROMPATH1 TO &FILENAME
COPY FILE &SFROMPATH2 TO &FILENAME

ON ERROR

CLOSE DATABASES 
